acme.validation.ticker.message		= The ticker must have exactly two capital letters and two digits, a dash, and between five or ten numbers, letters or underscores. Example: AB12-EX_Tick12
acme.validation.text.message   		= Must have from 1 to 255 characters
acme.validation.header.message  	= Must have from 1 to 75 characters

acme.validation.invention.parts.message = An invention needs at least one part to be published
acme.validation.invention.interval.message = End moment must be after start moment